# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER COMMIT .env TO GIT

# ─── Backend API ───────────────────────────
# Set to your Render backend URL after deploy
VITE_API_URL=https://your-backend.onrender.com
VITE_USE_MOCK=false

# ─── Firebase Frontend Config ──────────────
# Get from: Firebase Console → Project Settings
# → Your apps → Web app → SDK setup and config
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ─── Google Maps ───────────────────────────
# Get from: console.cloud.google.com → APIs → Credentials
# Restrict key to: Maps JavaScript API + Geocoding API
VITE_GOOGLE_MAPS_KEY=your-google-maps-key

# ─── Razorpay ──────────────────────────────
# Use test key only (rzp_test_xxx)
VITE_RAZORPAY_KEY=rzp_test_your_key_here
