# MongoDB Atlas connection string
# URL-encode special chars: # = %23
MONGODB_URL=mongodb+srv://user:pass%23word@cluster.mongodb.net/guidepay
MONGODB_DB_NAME=guidepay

# Firebase service account
FIREBASE_PROJECT_ID=guide-pay
FIREBASE_PRIVATE_KEY_ID=your_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@guide-pay.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_client_id

# Razorpay (test keys)
RAZORPAY_KEY_ID=rzp_test_mock_guidepay
RAZORPAY_KEY_SECRET=mock_secret_2026
RAZORPAY_MOCK_MODE=true

# App security
SECRET_KEY=guidepay-sentinelx-2026-secret-key-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS
FRONTEND_URL=https://guidepayklu.vercel.app
FRONTEND_URL_LOCAL=http://localhost:5173

# Environment
ENVIRONMENT=production

# OpenWeatherMap (free at openweathermap.org)
OPENWEATHER_API_KEY=fa196308bb6d360f299427eb37480021

# Trigger polling
TRIGGER_POLL_INTERVAL_MINUTES=15
